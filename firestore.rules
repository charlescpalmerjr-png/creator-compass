rules_version = '2';

// ============================================================
//  Firestore Security Rules
//  ------------------------------------------------------------
//  This is what keeps user data safe. It runs on Google's
//  servers — the client cannot bypass it. A signed-in user can
//  only ever read or write documents under their OWN uid.
//  Everyone else is denied by default.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's profile document: users/{uid}
    match /users/{uid} {
      // Only the owner can read or write their profile
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.email is string;
      allow update, delete: if request.auth != null && request.auth.uid == uid;

      // A user's saved blueprints: users/{uid}/blueprints/{id}
      match /blueprints/{blueprintId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
